# .env - 只保留 Settings 类中定义的字段
DATABASE_URL=postgresql://admin:123456@localhost:5200/amazon_scraper
RAW_DATA_DIR=./backend/app/scraper/amazon_data
PROCESSED_DATA_DIR=./backend/app/scraper/processed_data
INPUT_FOLDER=./backend/app/scraper/amazon_data
DEFAULT_POSTAL_CODE=90060
DEFAULT_DELAY_RANGE=3,6
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
SCHEDULED_HOUR=9
SCHEDULED_MINUTE=0

